# ── Concierge (chat) ─────────────────────────────────────────
# El chat arranca en modo IA siempre que haya al menos una key de
# proveedor configurada (abajo). Cae a FAQ determinista (coste 0 €) solo
# si no hay keys, se agota el presupuesto diario o falla toda la cadena.
# Para FORZAR el modo FAQ (p. ej. en pruebas), pon CHAT_MODE=faq.
CHAT_MODE=llm

# Proveedor de IA: cadena de fallback automática. Se prueban en orden
# los proveedores cuya key esté configurada; si todos fallan, el chat
# degrada a modo FAQ (nunca da error muerto). Orden: Groq → OpenRouter
# → Anthropic. (AI_PROVIDER ya no se usa; el orden es fijo.)

# Groq — free tier en console.groq.com (sin tarjeta, ~1000 msg/día).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — respaldo gratis. Crea una key en openrouter.ai/keys (sin
# tarjeta). Se envía una LISTA de modelos gratis: OpenRouter prueba el
# siguiente si el primero está saturado. Los modelos :free rotan con el
# tiempo; revisa openrouter.ai/models y ajusta la lista si alguno deja de
# existir. Límite típico free: ~20 req/min, ~200 req/día.
OPENROUTER_API_KEY=
OPENROUTER_MODELS=meta-llama/llama-3.3-70b-instruct:free,openai/gpt-oss-120b:free

# Anthropic — respaldo de pago opcional (última posición de la cadena).
# Solo se usa si pones una key. La suscripción de Claude Code NO incluye
# créditos de API.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Tope global de mensajes IA al día (kill switch de presupuesto).
# Al superarlo, el chat degrada a modo FAQ en vez de romperse.
CHAT_DAILY_LIMIT=400

# ── Notificación a Telegram (opcional) ───────────────────────
# Avisa a tu móvil cuando alguien pega una oferta o llega por una
# candidatura/campaña. Vacío = desactivado. Cómo obtenerlos:
#  1. Habla con @BotFather en Telegram → /newbot → copia el token.
#  2. Escribe algo a tu bot, luego abre:
#     https://api.telegram.org/bot<token>/getUpdates y copia el chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Analítica sin cookies (opcional; elegir UNA) ─────────────
NEXT_PUBLIC_GOATCOUNTER=
NEXT_PUBLIC_UMAMI_ID=
NEXT_PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js

# ── SEO ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://dnr-portfolio.vercel.app
